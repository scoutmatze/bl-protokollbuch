# Reverse Proxy + automatisches TLS. {$DOMAIN} kommt aus der Umgebung.
{$DOMAIN} {
	encode gzip

	# API
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Frontend (Phase 5): statische Vite-Dateien.
	# handle {
