# Kopie als infra/.env anlegen und Werte setzen. NIEMALS .env committen.

# --- Datenbank ---
POSTGRES_USER=protokoll
POSTGRES_PASSWORD=bitte-aendern
POSTGRES_DB=protokollbuch
DATABASE_URL=postgresql+psycopg://protokoll:bitte-aendern@db:5432/protokollbuch

# --- Redis / Worker-Queue ---
REDIS_URL=redis://redis:6379/0

# --- Ollama (lokales LLM) ---
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1          # endgueltige Wahl nach VPS-Hardware (siehe ADR 0001)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Auth ---
JWT_SECRET=bitte-langen-zufallswert-setzen
ACCESS_TOKEN_TTL_MIN=60

# --- Protokollbestand (read-only Mount in den Worker) ---
PROTOKOLL_SOURCE_DIR=/c/Users/MathiasFazekas/BUNDESAMT SANKT GEORG E.V. DPSG/Bundesleitung - Dokumente/BL-Sitzungen

# --- Betrieb ---
DOMAIN=protokollbuch.example.org
LOG_LEVEL=INFO

# --- Matching-Schwellen (anfangs konservativ) ---
MATCH_T_HIGH=0.82
MATCH_T_LOW=0.62
